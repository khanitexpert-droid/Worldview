# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local-only demo/test rasters (kept out of the repo + OneDrive; the
# originals live in C:\Users\usmaa\worldview-demo)
/public/demo_*.tif

# typescript
*.tsbuildinfo
next-env.d.ts

# local-only data artifacts (the GitHub Action publishes these to the `data` branch)
/events.json
/activity.json

# raw Global Energy Monitor source files (build-time inputs incl. a ~190 MB zip;
# the parsed public/infra_*.json outputs are what get committed). Ignore the whole
# drop folder except its README.
/gem-data/*
!/gem-data/README.md
